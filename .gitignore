# Python
__pycache__/
*.py[cod]
*.egg-info/
*.egg
.venv/
venv/

# OS
Thumbs.db
.DS_Store

# VSCode
.vscode/

# Claude
.claude/projects/
.claude/sessions/
.claude/tasks/
.claude/backups/
.claude/file-history/
.claude/scheduled_tasks*
.claude/telemetry/
.claude/plugins/
.claude/marketplaces/
.claude/ide/
.claude/claude.json
.claude/config.json

# Obsidian
.obsidian/workspace*
.obsidian/cache/
.obsidian/themes/
# 注意：.obsidian/plugins/ 不忽略，确保社区插件随仓库分发
# 新用户克隆后 Obsidian 自动识别已安装插件，无需手动去插件市场安装
# 但忽略插件内部的用户配置（每个人启动后自动生成自己的 data.json）
.obsidian/plugins/*/data.json

# Env
.env
*.local.json